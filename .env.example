# Database (must match DB_USER / DB_PASSWORD below)
DATABASE_URL=postgresql://marinedb:marinedev@localhost:5432/maritime_compliance
DB_USER=marinedb
DB_PASSWORD=marinedev

# Server
AUTH_SECRET=maritime-dev-secret-change-me
PORT=3000
HTTP_PORT=80
NODE_ENV=development
LOG_LEVEL=info

# Dashboard (empty = relative URLs via nginx; set to http://localhost:3200 for local dev without docker)
NEXT_PUBLIC_API_URL=

# Agent (Nebius inference — OpenAI-compatible)
NEBIUS_API_KEY=
NEBIUS_API_URL=https://api.studio.nebius.ai/v1/
NEBIUS_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-fast

# Agent (Tavily search — regulation lookup)
TAVILY_API_KEY=

# Agent (Composio — email notifications)
COMPOSIO_API_KEY=
ALERT_EMAIL=
