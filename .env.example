# ── Database ────────────────────────────────────────────────────────────────
# DB_USER / DB_PASSWORD are used by docker-compose to create the Postgres instance
DB_USER=maritime
DB_PASSWORD=maritime
DATABASE_URL=postgresql://maritime:maritime@localhost:5432/maritime

# ── Server ──────────────────────────────────────────────────────────────────
AUTH_SECRET=change-me-in-production   # REQUIRED — any long random string
NODE_ENV=development
LOG_LEVEL=info

# ── Dashboard ───────────────────────────────────────────────────────────────
# Empty = relative URLs through nginx (correct for docker-compose)
# Set to http://localhost:3200 for local dev without docker
NEXT_PUBLIC_API_URL=

# ── AI Agent — Nebius (primary LLM) ─────────────────────────────────────────
NEBIUS_API_KEY=
NEBIUS_API_URL=https://api.studio.nebius.ai/v1/
NEBIUS_MODEL=meta-llama/Llama-3.3-70B-Instruct

# ── AI Agent — Groq fallback (if Nebius credits unavailable) ────────────────
# Set NEBIUS_API_URL=https://api.groq.com/openai/v1/ and fill GROQ_API_KEY
# NEBIUS_MODEL=qwen/qwen3-32b
GROQ_API_KEY=

# ── Tavily — regulation and safety bulletin search ───────────────────────────
TAVILY_API_KEY=

# ── Composio — email alert notifications ─────────────────────────────────────
COMPOSIO_API_KEY=
ALERT_EMAIL=
